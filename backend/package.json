{
  "name": "clinical-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --exec tsx src/server.ts",
    "start": "node --enable-source-maps dist/server.js",
    "build": "tsc",
    "migrate": "node --experimental-specifier-resolution=node src/db.ts"
  },
  "dependencies": {
    "sqlite": "^4.1.2",
    "sqlite3": "^5.1.4",
    "bcrypt": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.19",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.14.2",
    "nodemon": "^2.0.22",
    "tsx": "^3.12.7",
    "typescript": "^5.8.3"
  }
}
